; ╭──────────────────────────────────────────────────────────╮
; │ GIT CONFIG                                               │
; ╰──────────────────────────────────────────────────────────╯

[user]
  name = "{{- .name -}}"
  email = "{{- .email -}}"
  signingkey = {{- .opsecret -}}

[gpg]
  format = ssh

[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
  allowedSignersFile = ~/.ssh/allowed_signers

[credential]
  helper = osxkeychain

[core]
  editor = "{{ .editor }}"
  longpaths = true
  pager = "delta"
  excludesFile = ~/.gitignore_global
  autocrlf = input
  
[init]
  defaultBranch = "master"
  templatedir = ~/.gittemplates

[commit]
  gpgsign = true
  
[push]
  default = upstream
  autoSetupRemote = true

[pull]
  ff = only

[stash]
  showPatch = true

[log]
  decorate = full

[status]
  showUntrackedFiles = all

[merge]
  conflictstyle = diff3
  stat = true

[advice]
  pushNonFastForward = false
  statusHints = false

[gitreview]
  remote = "origin"

[remote "origin"]
  fetch = +refs/pull/*/head:refs/remotes/origin/pr/*

[color]
  ui = "auto"
  status = "auto"
  diff = "auto"
  branch = "auto"
  interactive = "auto"

[pager]
  diff = delta
  log = delta
  reflog = delta
  show = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  features = side-by-side line-numbers decorations
  whitespace-error-style = 22 reverse

[delta "decorations"]
  commit-decoration-style = bold yellow box ul
  file-style = bold yellow ul
  file-decoration-style = none

[help]
  autocorrect = 1

{{- if eq .name "satya-claw" "Satya Claw" "Claw Satya" "Satya" }}
[url "git@github.com:satya-claw"]
  insteadOf = https://github.com/satya-claw
{{- end }}

