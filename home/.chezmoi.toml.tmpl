{{ $opsakey := promptStringOnce . "opsakey" "1Password Service Account Key" }}
{{ $name := promptStringOnce . "name" "Name" "Satya Claw" }}
{{ $email := promptStringOnce . "email" "Email Address" "ikoc.satya@gmail.com" }}

# ╭──────────────────────────────────────────────────────────╮
# │ CHEZMOI CONFIG                                           │
# ╰──────────────────────────────────────────────────────────╯

follow = true # follow symlinks
sourceDir = {{ .chezmoi.workingTree | quote }}
progress = true

[data]
  opsakey = {{ $opsakey | quote }}
  name = {{ $name | quote }}
  email = {{ $email | quote }}
  editor = "nvim"
  
[hooks.init.pre]
  command = "task"
  args = ["-d", {{- .chezmoi.sourceDir | quote -}}]

[hooks.read-source-state.pre]
  command = "{{- .chezmoi.workingTree -}}/.darwin-install-prerequisites.sh"

[git]
  autoCommit = true
  autoPush = true

[diff]
  pager = "delta"
  exclude = ["scripts", "externals"]

[merge]
  command = "nvim"
  args = ["-d", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}", "{{ "{{" }} .Target {{ "}}" }}"]
  
[status]
  exclude = ["always"]

[scriptEnv]
  OP_SERVICE_ACCOUNT_TOKEN = {{ $opsakey | quote }}
  DEFAULTS = "0"
  TRACE = "0"
  VERBOSE = "0"
