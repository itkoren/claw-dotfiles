#!{{ lookPath "sh" }}

# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

read -p "Going to install packages! skip? (y/n): " yn
if [[ "$yn" =~ ^[Yy]$ ]]; then
  echo "Skipping..."
  exit 0
fi

echo "Installing Homebrew taps and brews..."

# -------------------------
# Install taps and brews
# -------------------------
tmp_brewfile=$(mktemp)

{{ range .packages.taps -}}
echo "tap {{ . }}" >> "$tmp_brewfile"
{{ end }}

{{ range .packages.brews -}}
echo "brew {{ . }}" >> "$tmp_brewfile"
{{ end }}

brew bundle --file="$tmp_brewfile"
rm "$tmp_brewfile"

{{ if gt (len .packages.mas) 0 }}

# -------------------------
# Ensure mas exists (only if MAS packages are defined)
# -------------------------
if ! command -v mas >/dev/null 2>&1; then
  echo "Installing mas..."
  brew install mas
fi

{{ end }}

# -------------------------
# Install or update casks
# -------------------------
casks_to_install_or_update=""

for cask in {{ range .packages.casks }}{{ . }} {{ end }}; do
  if ! brew list --cask "$cask" &>/dev/null || brew outdated --cask "$cask" | grep -q .; then
    casks_to_install_or_update+="$cask"$'\n'
  fi
done

if [[ -n "$casks_to_install_or_update" ]]; then
  echo "Casks to install or update:"
  echo "$casks_to_install_or_update"

  tmp_brewfile=$(mktemp)

  while IFS= read -r c; do
    [[ -z "$c" ]] && continue
    echo "cask \"$c\"" >> "$tmp_brewfile"
  done <<< "$casks_to_install_or_update"

  brew bundle --file="$tmp_brewfile" --force
  rm "$tmp_brewfile"
else
  echo "No missing or outdated casks."
fi

# -------------------------
# Install Xcode separately
# -------------------------
{{ $xcode_id := "497799835" }}
{{ if gt (len .packages.mas) 0 }}
{{ $exclude_universal_package := "" }}
{{ range .packages.mas }}
  {{ if eq .id $xcode_id }}
    {{ $exclude_universal_package = . }}
  {{ end }}
{{ end }}
{{ if $exclude_universal_package }}
# Install the Xcode specific app (id: 497799835) separately if needed
mas install {{ $exclude_universal_package.id }}

# Accept T&Cs if needed
if ! sudo xcodebuild -license check &>/dev/null; then
  echo "Xcode license has not been accepted."
  echo "Accepting the Xcode license..."

  # Automatically accept the license
  sudo xcodebuild -license accept

  echo "Xcode license accepted."
fi
{{ end }}
{{ end }}

# -------------------------
# Install other MAS apps
# -------------------------
{{ range .packages.mas }}
{{ if ne .id $xcode_id }}
echo "Installing {{ .name }} (id: {{ .id }}) via MAS..."
mas install {{ .id }} || true
{{ end }}
{{ end }}

# -------------------------
# Install ASDF plugins
# -------------------------
{{ range .packages.asdf }}

plugin="{{ .plugin }}"

if ! asdf plugin list | grep -q "^$plugin$"; then
  echo "Adding ASDF plugin $plugin..."
  asdf plugin add "$plugin"
fi

{{ range .versions }}
echo "Installing $plugin version {{ . }}..."
asdf install "$plugin" "{{ . }}" || true
{{ end }}

{{ end }}

echo "All packages processed."
